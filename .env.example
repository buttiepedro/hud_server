# ── Proxmox (required) ───────────────────────────────────────────────────────
PROXMOX_HOST=192.168.1.10
PROXMOX_USER=root@pam
PROXMOX_TOKEN_NAME=hud
PROXMOX_TOKEN_VALUE=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Import your Proxmox CA cert instead of disabling SSL verification
# PROXMOX_CA_CERT=/app/certs/proxmox-ca.pem
# Only set to false for local testing, never in production
PROXMOX_VERIFY_SSL=true

# ── Docker SSH (optional — auto-discovered from Proxmox IPs) ─────────────────
DOCKER_SSH_USER=root
DOCKER_SSH_KEY_PATH=/app/certs/id_ed25519
# Force-add extra IPs beyond what Proxmox reports (comma-separated)
# DOCKER_SSH_EXTRA_HOSTS=192.168.1.50,192.168.1.51

# ── Traefik (optional) ────────────────────────────────────────────────────────
TRAEFIK_API_URL=http://192.168.1.30:8080
# TRAEFIK_API_USER=admin
# TRAEFIK_API_PASSWORD=secret

# ── Cloudflare (optional) ─────────────────────────────────────────────────────
# CLOUDFLARE_API_TOKEN=your_cf_api_token
# CLOUDFLARE_ACCOUNT_ID=your_account_id
# cloudflared local Prometheus metrics endpoint
# CLOUDFLARED_METRICS_URL=http://192.168.1.31:20241

# ── NAT inspection (optional — SSH to Proxmox host) ──────────────────────────
# NAT_SSH_HOST=192.168.1.10
# NAT_SSH_USER=root
# NAT_SSH_KEY_PATH=/app/certs/id_ed25519

# ── App ───────────────────────────────────────────────────────────────────────
POLL_INTERVAL_PROXMOX=30
POLL_INTERVAL_DOCKER=15
POLL_INTERVAL_TRAEFIK=60
POLL_INTERVAL_CLOUDFLARE=120
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Static token protecting the API — generate with: openssl rand -hex 32
HUD_API_TOKEN=change_me_to_a_random_32_char_secret
