# ─────────────────────────────────────────────────────────────────────────────
# HUD Server — Environment Configuration
#
# These variables are read by Docker Compose at startup (port mapping, Traefik
# labels) and must be set before running `docker compose up`.
#
# All application settings (Proxmox credentials, SSH keys, Traefik/Cloudflare/
# NAT integrations, HUD token) are configured through the browser setup wizard
# at http://YOUR_SERVER_IP:3000 on first launch, and saved to data/config.json.
# ─────────────────────────────────────────────────────────────────────────────

# External port the frontend listens on
HUD_PORT=3000

# Your public domain — used by Traefik to route traffic to the HUD
# Leave empty if you're not using Traefik (access via port only)
HUD_DOMAIN=hud.yourdomain.com

# Traefik entrypoint name (default: websecure)
# Use "web" for HTTP-only Traefik, "websecure" for HTTPS+TLS
TRAEFIK_ENTRYPOINT=web

# ─────────────────────────────────────────────────────────────────────────────
# MANUAL OVERRIDE (optional)
#
# If you prefer to configure the app without the wizard, uncomment and fill
# these variables. They are also useful for scripted/automated deployments.
# Values set here are overridden by data/config.json (written by the wizard).
# ─────────────────────────────────────────────────────────────────────────────

# PROXMOX_HOST=10.10.10.10
# PROXMOX_USER=root@pam
# PROXMOX_TOKEN_NAME=hud
# PROXMOX_TOKEN_VALUE=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# PROXMOX_VERIFY_SSL=false

# DOCKER_SSH_KEY_PATH=/app/data/id_ed25519
# DOCKER_SSH_EXTRA_HOSTS=10.10.10.30,10.10.10.40

# TRAEFIK_API_URL=http://traefik:8080

# CLOUDFLARE_API_TOKEN=your_cf_api_token
# CLOUDFLARE_ACCOUNT_ID=your_account_id
# CLOUDFLARE_TUNNEL_NAME=traefik
# CLOUDFLARED_METRICS_URL=http://cloudflared:20241

# NAT_SSH_HOST=10.10.10.10
# NAT_SSH_USER=root
# NAT_SSH_KEY_PATH=/app/data/id_ed25519

# HUD_API_TOKEN=change_me_to_a_random_secret
# ALLOWED_ORIGINS=http://YOUR_SERVER_IP:3000,https://hud.yourdomain.com

# POLL_INTERVAL_PROXMOX=30
# POLL_INTERVAL_DOCKER=15
# POLL_INTERVAL_TRAEFIK=60
# POLL_INTERVAL_CLOUDFLARE=120
